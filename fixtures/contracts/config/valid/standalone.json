{
  "schema_version": "v1alpha1",
  "agent": {
    "agent_id": null,
    "environment_id": "prod-cn",
    "instance_name": "local"
  },
  "control_plane": {
    "enabled": false,
    "endpoint": null,
    "tls_mode": null,
    "auth_mode": null
  },
  "paths": {
    "root_dir": "/var/lib/wp-agent",
    "run_dir": "/var/lib/wp-agent/run",
    "state_dir": "/var/lib/wp-agent/state",
    "log_dir": "/var/log/wp-agent"
  },
  "execution": {
    "max_running_actions": 1,
    "cancel_grace_ms": 5000,
    "default_stdout_limit_bytes": 1048576,
    "default_stderr_limit_bytes": 1048576
  }
}
